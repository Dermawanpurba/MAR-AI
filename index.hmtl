<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title id="app-title-tag">MAR AI Pro - Enterprise</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #0f172a; color: #f8fafc; overflow-x: hidden; min-height: 100vh; }
        .blob-container { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; overflow: hidden; filter: blur(100px); }
        .blob { position: absolute; width: 500px; height: 500px; border-radius: 50%; opacity: 0.15; animation: move 25s infinite alternate ease-in-out; }
        .blob-1 { background: #3b82f6; top: -10%; left: -10%; }
        .blob-2 { background: #8b5cf6; bottom: -10%; right: -10%; animation-delay: -5s; }
        @keyframes move { from { transform: translate(0, 0) scale(1); } to { transform: translate(150px, 100px) scale(1.3); } }
        
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.08); }
        .glass-dark { background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(30px); border-right: 1px solid rgba(255, 255, 255, 0.05); }
        .active-menu { background: linear-gradient(90deg, rgba(59, 130, 246, 0.2) 0%, rgba(59, 130, 246, 0) 100%); border-left: 4px solid #3b82f6; color: #60a5fa; }
        
        #video { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: 2rem; transform: scaleX(1); }
        .spinner { border: 3px solid rgba(255,255,255,.1); border-radius: 50%; border-top: 3px solid #3b82f6; width: 32px; height: 32px; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }

        .stat-bar { height: 8px; border-radius: 4px; background: rgba(59, 130, 246, 0.1); position: relative; overflow: hidden; }
        .stat-fill-blue { height: 100%; background: linear-gradient(90deg, #3b82f6, #60a5fa); width: 0%; transition: width 1.5s cubic-bezier(0.34, 1.56, 0.64, 1); }
        .stat-fill-purple { height: 100%; background: linear-gradient(90deg, #8b5cf6, #a78bfa); width: 0%; transition: width 1.5s cubic-bezier(0.34, 1.56, 0.64, 1); }
    </style>
</head>
<body class="flex flex-col md:flex-row min-h-screen">
    <div class="blob-container">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
    </div>

    <!-- SIDEBAR -->
    <aside class="hidden md:flex flex-col w-72 h-screen sticky top-0 glass-dark z-50 p-8">
        <div class="flex items-center gap-4 mb-12">
            <div id="app-logo-container" class="p-3 bg-blue-600 rounded-2xl shadow-xl shadow-blue-600/30 overflow-hidden flex items-center justify-center">
                <i id="default-logo-icon" data-lucide="cpu" class="text-white w-6 h-6"></i>
                <img id="custom-logo-img" src="" class="hidden w-8 h-8 object-contain" />
            </div>
            <div>
                <h1 id="app-name-display" class="text-xl font-bold tracking-tight">MAR AI Pro</h1>
                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Enterprise Edition</p>
            </div>
        </div>
        <nav class="flex-1 space-y-3">
            <button onclick="switchMenu('scan')" id="btn-scan" class="menu-item flex items-center gap-4 w-full p-4 rounded-2xl transition-all hover:bg-white/5 active-menu font-medium text-sm">
                <i data-lucide="camera" class="w-5 h-5"></i> Scan Laporan
            </button>
            <button onclick="switchMenu('history')" id="btn-history" class="menu-item flex items-center gap-4 w-full p-4 rounded-2xl transition-all hover:bg-white/5 font-medium text-sm">
                <i data-lucide="layout-grid" class="w-5 h-5"></i> Riwayat Data
            </button>
            <button onclick="switchMenu('dashboard')" id="btn-dashboard" class="menu-item flex items-center gap-4 w-full p-4 rounded-2xl transition-all hover:bg-white/5 font-medium text-sm">
                <i data-lucide="bar-chart-3" class="w-5 h-5"></i> Dashboard
            </button>
            <button onclick="switchMenu('settings')" id="btn-settings" class="menu-item flex items-center gap-4 w-full p-4 rounded-2xl transition-all hover:bg-white/5 font-medium text-sm">
                <i data-lucide="settings-2" class="w-5 h-5"></i> AI & App Settings
            </button>
        </nav>
        <div class="mt-auto pt-8 border-t border-white/5 text-center text-[10px] text-slate-600">
            develop by : dermawan.prb@gmail.com
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex-1 p-4 md:p-12 pb-32 md:pb-12 overflow-y-auto">
        
        <!-- SECTION SCAN -->
        <div id="section-scan" class="content-section max-w-2xl mx-auto space-y-8 animate-in fade-in">
            <h2 class="text-3xl font-bold">Scan Laporan</h2>
            <div class="glass p-4 rounded-[2.5rem] relative">
                <div class="relative rounded-[2rem] overflow-hidden bg-slate-900 shadow-inner">
                    <video id="video" autoplay playsinline></video>
                </div>
                <div class="p-6">
                    <button onclick="captureAndAnalyze()" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-5 rounded-2xl flex items-center justify-center gap-3 active:scale-[0.98] transition-all shadow-xl shadow-blue-600/20">
                        <i data-lucide="zap" class="w-5 h-5"></i> Ambil & Analisis AI
                    </button>
                </div>
            </div>

            <!-- RESULT FORM -->
            <div id="result-container" class="hidden space-y-6 glass p-8 rounded-[2.5rem] border border-blue-500/20 shadow-2xl">
                <div class="flex items-center gap-3 border-b border-white/5 pb-4">
                    <i data-lucide="check-circle" class="text-emerald-400"></i>
                    <h3 class="font-bold text-lg">Hasil Ekstraksi AI</h3>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-[10px] uppercase font-bold text-slate-500 ml-1">Nama Mekanik</label>
                        <input type="text" id="res-nama" list="db-mekanik" class="w-full bg-white/5 border border-white/10 rounded-xl p-4 outline-none focus:border-blue-500 transition-colors" placeholder="Ketik nama...">
                        
                        <!-- DATABASE MEKANIK -->
                        <datalist id="db-mekanik">
                            <option value="SAHARUDIN">MEKANIK HE</option>
                            <option value="ARISMAN">MEKANIK HE</option>
                            <option value="BAHARUDDIN (1)">MEKANIK HE</option>
                            <option value="WAHYU BASUKIYONO">MEKANIK HE</option>
                            <option value="JUHARKAM PELU PESSY">MEKANIK</option>
                            <option value="GATOT EFENDI">MEKANIK HE</option>
                            <option value="YEDI SUSANTO">ASST MEKANIK HE</option>
                            <option value="NISCAYAH">ASST MEKANIK HE</option>
                            <option value="APRILIAN MASKUR">HLP. MEKANIK HE</option>
                            <option value="JONISER">HLP. MEKANIK HE</option>
                            <option value="PINKAN NUR FOIQI">HLP. MEKANIK HE</option>
                            <option value="MEIKEL LAHANG">HLP. MEKANIK HE</option>
                            <option value="SAIDIL">HLP. MEKANIK HE</option>
                            <option value="AGUS">MEKANIK BSS</option>
                            <option value="RIZKI RAHMA PRIADI">MEKANIK BSS</option>
                            <option value="PURWANTO">MEKANIK BSS</option>
                            <option value="PATRISIUS MAU SURI">MEKANIK BSS</option>
                            <option value="MUHAMMAD NUR IKHWAN">ASST MEKANIK BSS</option>
                            <option value="PAISAL">ASST MEKANIK BSS</option>
                            <option value="IKBAL JAELANI">HLP. MEKANIK BSS</option>
                            <option value="SYARIFUDDIN">HLP. MEKANIK BSS</option>
                            <option value="REVALDO">HLP. MEKANIK BSS</option>
                            <option value="TONI BIN MUHAMMAD">HLP. MEKANIK BSS</option>
                            <option value="BAHARUDDIN (2)">HLP. MEKANIK BSS</option>
                            <option value="MARKUS ALFIAN">HLP. MEKANIK BSS</option>
                            <option value="VICTOR ARTHYA PATRA">HLP. MEKANIK BSS</option>
                            <option value="DARIUS GAT SUNA">HLP. MEKANIK BSS</option>
                            <option value="SAMUEL FERNANDO DALOPES">HLP. MEKANIK BSS</option>
                            <option value="MARTINUS MARKI">MEKANIK BSS</option>
                            <option value="GAYUS BALAN">HLP. MEKANIK BSS</option>
                            <option value="MARTIN MARKI">HLP. MEKANIK BSS</option>
                            <option value="PETRUS SALENTIUS L">WELDER</option>
                            <option value="FRANS PHILIPUS">HLP. MEKANIK BSS</option>
                            <option value="BUDI JAK SONO">ASST. WELDER</option>
                            <option value="RAHMAT">ASST. WELDER</option>
                            <option value="ROBY">ASST ELECTRICAL</option>
                            <option value="TIN NUR">ASST ELECTRIC</option>
                            <option value="DWI TUNGGAL ANDAYANI">ASST SUPPORT</option>
                            <option value="MARTINUS KAROWE LEIN">GREASING & TYRE BSS</option>
                            <option value="FEBRI SETIAWAN">WASHING BSS</option>
                            <option value="MARSYANUS">HELPER MEKANIK</option>
                            <option value="MATIUS AJAN">ASST TYRE BSS</option>
                            <option value="KORNELIUS NGERUNG">ASST TYRE BSS</option>
                            <option value="ERIK NOVELIANUS">ASST TYRE BSS</option>
                            <option value="MUHAMMAD SUGENG ANTO">MEKANIK SUPPORT</option>
                            <option value="NCUK IMANG">HELPER SUPPORT</option>
                            <option value="ANTONIO ALFA REZA">HELPER SUPPORT</option>
                            <option value="VARIO DANISTO">HELPER MEKANIK</option>
                            <option value="MARDEN IBAN">HELPER SUPPORT</option>
                            <option value="HARUN">MEKANIK</option>
                            <option value="WAWAN">MEKANIK ELECTRIC</option>
                            <option value="AGUS WARAS">MEKANIK</option>
                            <option value="SERAJUDDIN">WELDER</option>
                            <option value="JUHARKAM PELUPESSY">MEKANIK</option>
                            <option value="SYARIFUDIN">HLP. MEKANIK BSS</option>
                        </datalist>
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] uppercase font-bold text-slate-500 ml-1">Shift</label>
                        <input type="text" id="res-shift" class="w-full bg-white/5 border border-white/10 rounded-xl p-4 outline-none">
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] uppercase font-bold text-slate-500 ml-1">Tanggal</label>
                        <input type="date" id="res-tanggal" class="w-full bg-white/5 border border-white/10 rounded-xl p-4 outline-none">
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] uppercase font-bold text-slate-500 ml-1">No WO</label>
                        <input type="text" id="res-wo" class="w-full bg-white/5 border border-white/10 rounded-xl p-4 outline-none">
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] uppercase font-bold text-slate-500 ml-1 text-blue-400">Jam Mulai</label>
                        <input type="time" id="res-start" class="w-full bg-white/5 border border-white/10 rounded-xl p-4 outline-none">
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] uppercase font-bold text-slate-500 ml-1 text-red-400">Jam Selesai</label>
                        <input type="time" id="res-stop" class="w-full bg-white/5 border border-white/10 rounded-xl p-4 outline-none">
                    </div>
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] uppercase font-bold text-slate-500 ml-1">Deskripsi Pekerjaan</label>
                    <textarea id="res-desc" rows="3" class="w-full bg-white/5 border border-white/10 rounded-xl p-4 outline-none resize-none"></textarea>
                </div>
                <button onclick="saveToSheets()" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-5 rounded-2xl shadow-lg shadow-emerald-600/20 transition-all">
                    Simpan Ke Database
                </button>
            </div>
        </div>

        <!-- SECTION HISTORY -->
        <div id="section-history" class="content-section hidden space-y-8 animate-in fade-in">
            <h2 class="text-3xl font-bold px-2">Riwayat Laporan</h2>
            <div class="glass rounded-[2.5rem] overflow-hidden overflow-x-auto border border-white/5 shadow-2xl">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-white/5 text-[10px] uppercase font-bold text-slate-500">
                        <tr class="border-b border-white/5">
                            <th class="p-6">ID / No WO</th>
                            <th class="p-6">Tanggal</th>
                            <th class="p-6">Jam (Start - Stop)</th>
                            <th class="p-6">Nama Mekanik</th>
                            <th class="p-6">Status</th>
                        </tr>
                    </thead>
                    <tbody id="table-body" class="text-sm divide-y divide-white/5"></tbody>
                </table>
            </div>
        </div>

        <!-- DASHBOARD -->
        <div id="section-dashboard" class="content-section hidden space-y-8 animate-in fade-in">
            <h2 class="text-3xl font-bold px-2">Dashboard Analitik</h2>
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- Overview Cards -->
                <div class="space-y-6">
                    <div class="glass p-8 rounded-[2.5rem] space-y-6">
                        <h3 class="font-bold text-blue-400 flex items-center gap-2">
                            <i data-lucide="layout-dashboard" class="w-5 h-5"></i> Ringkasan Utama
                        </h3>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="p-6 bg-white/5 rounded-2xl">
                                <p class="text-[10px] uppercase font-bold text-slate-500">Total Laporan</p>
                                <h4 id="stat-total" class="text-4xl font-black mt-2">0</h4>
                            </div>
                            <div class="p-6 bg-white/5 rounded-2xl">
                                <p class="text-[10px] uppercase font-bold text-slate-500">Unit Teraktif</p>
                                <h4 id="stat-unit" class="text-2xl font-black mt-2 truncate">-</h4>
                            </div>
                        </div>
                    </div>

                    <!-- Highlight Records -->
                    <div class="glass p-8 rounded-[2.5rem] space-y-6 border-l-4 border-emerald-500">
                        <h3 class="font-bold text-emerald-400 flex items-center gap-2">
                            <i data-lucide="award" class="w-5 h-5"></i> Rekor Jam Kerja
                        </h3>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between p-4 bg-emerald-500/5 rounded-2xl border border-emerald-500/10">
                                <div>
                                    <p class="text-[10px] uppercase font-bold text-slate-500">Bulan Terpadat (Max Hours)</p>
                                    <h4 id="stat-max-month" class="text-lg font-bold text-emerald-400">-</h4>
                                </div>
                                <div id="stat-max-val" class="text-2xl font-black">0h</div>
                            </div>
                            <div class="flex items-center justify-between p-4 bg-red-500/5 rounded-2xl border border-red-500/10">
                                <div>
                                    <p class="text-[10px] uppercase font-bold text-slate-500">Bulan Terlonggar (Min Hours)</p>
                                    <h4 id="stat-min-month" class="text-lg font-bold text-red-400">-</h4>
                                </div>
                                <div id="stat-min-val" class="text-2xl font-black">0h</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Monthly Charts -->
                <div class="space-y-6">
                    <div class="glass p-8 rounded-[2.5rem] space-y-6">
                        <h3 class="font-bold text-blue-400 flex items-center gap-2">
                            <i data-lucide="calendar" class="w-5 h-5"></i> Tren Laporan Per Bulan
                        </h3>
                        <div id="monthly-stats-container" class="space-y-4">
                            <!-- Bars injected here -->
                        </div>
                    </div>
                    
                    <div class="glass p-8 rounded-[2.5rem] space-y-6">
                        <h3 class="font-bold text-purple-400 flex items-center gap-2">
                            <i data-lucide="clock" class="w-5 h-5"></i> Tren Jam Kerja Per Bulan
                        </h3>
                        <div id="monthly-hours-container" class="space-y-4">
                            <!-- Bars injected here -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECTION SETTINGS -->
        <div id="section-settings" class="content-section hidden max-w-2xl mx-auto space-y-8 animate-in fade-in">
            <h2 class="text-3xl font-bold">App Configuration</h2>
            <div class="glass p-8 rounded-[2.5rem] space-y-6">
                <h3 class="font-bold text-blue-400 flex items-center gap-2"><i data-lucide="palette"></i> Branding Settings</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-[10px] uppercase font-bold text-slate-500 ml-1">App Name</label>
                        <input type="text" id="set-app-name" class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 outline-none">
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] uppercase font-bold text-slate-500 ml-1">Logo URL</label>
                        <input type="text" id="set-app-logo" class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 outline-none">
                    </div>
                </div>
                <button onclick="saveBrandingSettings()" class="w-full bg-blue-600 py-4 rounded-2xl font-bold shadow-lg shadow-blue-600/20 transition-all">Simpan Branding</button>
            </div>
            
            <div class="glass p-8 rounded-[2.5rem] space-y-6">
                <h3 class="font-bold text-purple-400 flex items-center gap-2"><i data-lucide="bot"></i> AI Provider</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <select id="ai-provider" onchange="updateModelOptions()" class="bg-slate-900 border border-white/10 rounded-2xl p-4 outline-none">
                        <option value="gemini">Google Gemini</option>
                        <option value="gpt">OpenAI (GPT-4o)</option>
                        <option value="openrouter">OpenRouter (Free)</option>
                    </select>
                    <select id="ai-model" class="bg-slate-900 border border-white/10 rounded-2xl p-4 outline-none"></select>
                </div>
                <input type="password" id="ai-key" placeholder="API Key" class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 outline-none">
                <button onclick="saveAISettings()" class="w-full bg-purple-600 py-4 rounded-2xl font-bold shadow-lg shadow-purple-600/20 transition-all">Simpan Konfigurasi AI</button>
            </div>
        </div>
    </main>

    <!-- MOBILE NAV -->
    <nav class="md:hidden fixed bottom-6 left-6 right-6 h-20 glass rounded-3xl flex justify-around items-center z-[100] border-white/20 shadow-2xl">
        <button onclick="switchMenu('scan')" class="p-4 text-slate-400 hover:text-blue-500 transition-all"><i data-lucide="camera" class="w-6 h-6"></i></button>
        <button onclick="switchMenu('history')" class="p-4 text-slate-400 hover:text-blue-500 transition-all"><i data-lucide="table-2" class="w-6 h-6"></i></button>
        <button onclick="switchMenu('dashboard')" class="p-4 text-slate-400 hover:text-blue-500 transition-all"><i data-lucide="bar-chart-3" class="w-6 h-6"></i></button>
        <button onclick="switchMenu('settings')" class="p-4 text-slate-400 hover:text-blue-500 transition-all"><i data-lucide="settings-2" class="w-6 h-6"></i></button>
    </nav>

    <!-- LOADER -->
    <div id="loader" class="fixed inset-0 bg-slate-950/95 backdrop-blur-3xl z-[999] hidden flex flex-col items-center justify-center gap-8">
        <div class="spinner"></div>
        <div class="text-center">
            <p id="loader-text" class="text-white font-bold text-xl mb-1">Menganalisis...</p>
            <p class="text-slate-500 text-sm animate-pulse">AI sedang mengekstraksi data laporan Anda</p>
        </div>
    </div>

    <script>
        const canvas = document.createElement('canvas');
        let localData = [];

        // ⚡ FETCH API WRAPPER FOR NETLIFY DEPLOYMENT
        const GAS_API_URL = "https://script.google.com/macros/s/AKfycbxxA685vYhG69ROil283UQZbftCozGxDbb3MY1bM3cOvCUUCSgaD3HhEkBJ8Q6d08jE/exec";

        const callGAS = async (actionName, params = null) => {
            const config = JSON.parse(localStorage.getItem('mar_ai_config') || '{}');
            
            try {
                const response = await fetch(GAS_API_URL, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'text/plain;charset=utf-8', // Bypass preflight limits
                    },
                    body: JSON.stringify({
                        action: actionName,
                        params: params,
                        config: config
                    })
                });
                
                if (!response.ok) {
                    throw new Error(`HTTP status ${response.status}`);
                }

                const result = await response.json();
                if (result.error) throw new Error(result.error);
                return result.data;
            } catch (err) {
                console.warn(`[Fetch API Error] Gagal terhubung. Beralih ke MOCK DATA untuk: ${actionName}. Error:`, err);
                
                // Fallback Mock Data agar UI tidak freeze
                return new Promise((resolve) => {
                    setTimeout(() => {
                        if (actionName === 'getReportData') {
                            resolve([
                                {id: "MAR-01", no_wo: "WO-101", tanggal: "2024-03-10", time_start: "08:00", time_stop: "16:00", nama: "Budi", code_unit: "EXCA-01"},
                                {id: "MAR-02", no_wo: "WO-102", tanggal: "2024-03-12", time_start: "09:00", time_stop: "12:00", nama: "Andi", code_unit: "DZR-05"},
                                {id: "MAR-03", no_wo: "WO-103", tanggal: "2024-04-05", time_start: "08:00", time_stop: "18:00", nama: "Budi", code_unit: "EXCA-01"}
                            ]);
                        }
                        else if (actionName === 'saveReport') {
                            localData.unshift({...params, id: "MAR-SIM-" + Date.now(), timestamp: new Date().toISOString()});
                            resolve({ success: true });
                        }
                        else if (actionName === 'analyzeImageWithAI') {
                            resolve({
                                nama: "Mekanik Simulasi", shift: "Day", tanggal: new Date().toISOString().split('T')[0], no_wo: "WO-9999", time_start: "08:00", time_stop: "10:30", description: "Simulasi Analisis Teks (Mode Fallback karena fetch API gagal)."
                            });
                        }
                        else resolve({});
                    }, 800);
                });
            }
        };

        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            initAppBranding();
            initCamera();
            loadAISettings();
            loadAllData();
        });

        function initAppBranding() {
            const config = JSON.parse(localStorage.getItem('mar_app_config') || '{"name":"MAR AI Pro","logo":""}');
            document.getElementById('app-name-display').innerText = config.name;
            document.getElementById('set-app-name').value = config.name;
            if (config.logo) {
                document.getElementById('default-logo-icon').classList.add('hidden');
                document.getElementById('custom-logo-img').src = config.logo;
                document.getElementById('custom-logo-img').classList.remove('hidden');
            }
        }

        function saveBrandingSettings() {
            const name = document.getElementById('set-app-name').value || 'MAR AI Pro';
            const logo = document.getElementById('set-app-logo').value;
            localStorage.setItem('mar_app_config', JSON.stringify({ name, logo }));
            initAppBranding();
            Swal.fire('Berhasil', 'Branding diperbarui!', 'success');
        }

        async function initCamera() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "environment" } });
                document.getElementById('video').srcObject = stream;
            } catch (err) { console.warn("Kamera tidak aktif."); }
        }

        function loadAISettings() {
            const saved = JSON.parse(localStorage.getItem('mar_ai_config') || '{"provider":"gemini","model":"gemini-2.5-flash-preview-09-2025","apiKey":""}');
            document.getElementById('ai-provider').value = saved.provider;
            updateModelOptions(saved.model);
            document.getElementById('ai-key').value = saved.apiKey;
        }

        function updateModelOptions(selectedModel = null) {
            const provider = document.getElementById('ai-provider').value;
            const modelSelect = document.getElementById('ai-model');
            let options = '';
            if (provider === 'gemini') options = '<option value="gemini-2.5-flash-preview-09-2025">Gemini 2.5 Flash</option>';
            else if (provider === 'gpt') options = '<option value="gpt-4o">GPT-4o</option>';
            else options = '<option value="free-model">Free Vision Model</option>';
            modelSelect.innerHTML = options;
            if (selectedModel) modelSelect.value = selectedModel;
        }

        function saveAISettings() {
            const config = {
                provider: document.getElementById('ai-provider').value,
                model: document.getElementById('ai-model').value,
                apiKey: document.getElementById('ai-key').value
            };
            localStorage.setItem('mar_ai_config', JSON.stringify(config));
            Swal.fire('Berhasil', 'Konfigurasi AI disimpan!', 'success');
        }

        async function captureAndAnalyze() {
            const config = JSON.parse(localStorage.getItem('mar_ai_config') || '{}');
            if (!config.apiKey) return Swal.fire('Error', 'Harap isi API Key di menu Settings!', 'warning');

            const video = document.getElementById('video');
            canvas.width = video.videoWidth || 640; canvas.height = video.videoHeight || 480;
            canvas.getContext('2d').drawImage(video, 0, 0);
            const b64 = canvas.toDataURL('image/png').split(',')[1];
            
            toggleLoader(true, "AI sedang menganalisis dokumen...");
            try {
                const res = await callGAS('analyzeImageWithAI', b64);
                toggleLoader(false);
                document.getElementById('res-nama').value = res.nama || '';
                document.getElementById('res-shift').value = res.shift || '';
                document.getElementById('res-tanggal').value = res.tanggal || '';
                document.getElementById('res-wo').value = res.no_wo || '';
                document.getElementById('res-start').value = res.time_start || '';
                document.getElementById('res-stop').value = res.time_stop || '';
                document.getElementById('res-desc').value = res.description || '';
                document.getElementById('result-container').classList.remove('hidden');
                document.getElementById('result-container').scrollIntoView({behavior: 'smooth'});
            } catch (err) {
                toggleLoader(false);
                Swal.fire('Error', err.message, 'error');
            }
        }

        async function saveToSheets() {
            const data = { 
                nama: document.getElementById('res-nama').value, 
                shift: document.getElementById('res-shift').value, 
                tanggal: document.getElementById('res-tanggal').value, 
                no_wo: document.getElementById('res-wo').value, 
                time_start: document.getElementById('res-start').value,
                time_stop: document.getElementById('res-stop').value,
                description: document.getElementById('res-desc').value 
            };
            toggleLoader(true, "Menyimpan ke Cloud...");
            try {
                await callGAS('saveReport', data);
                toggleLoader(false);
                Swal.fire('Sukses', 'Laporan berhasil disimpan!', 'success');
                document.getElementById('result-container').classList.add('hidden');
                loadAllData();
            } catch (err) { toggleLoader(false); Swal.fire('Error', err.message, 'error'); }
        }

        async function loadAllData() {
            try {
                const res = await callGAS('getReportData');
                localData = res || [];
                renderHistory();
                renderDashboard();
            } catch (err) { console.error(err); }
        }

        function renderHistory() {
            const body = document.getElementById('table-body');
            body.innerHTML = localData.map(r => `
                <tr class="hover:bg-white/5 border-b border-white/5 transition-all">
                    <td class="p-6">
                        <div class="text-[10px] text-slate-500 font-bold">${r.id || '-'}</div>
                        <div class="font-bold text-blue-400">${r.no_wo || '-'}</div>
                    </td>
                    <td class="p-6 font-semibold">${r.tanggal || '-'}</td>
                    <td class="p-6">
                        <span class="text-blue-400 font-bold">${r.time_start || '--:--'}</span>
                        <span class="text-slate-500 mx-1">→</span>
                        <span class="text-red-400 font-bold">${r.time_stop || '--:--'}</span>
                    </td>
                    <td class="p-6 text-slate-200">${r.nama || '-'}</td>
                    <td class="p-6"><span class="bg-emerald-400/10 text-emerald-400 text-[10px] font-bold px-2 py-1 rounded">Synced</span></td>
                </tr>
            `).join('');
        }

        function calculateDuration(start, stop) {
            if (!start || !stop) return 0;
            const [h1, m1] = start.split(':').map(Number);
            const [h2, m2] = stop.split(':').map(Number);
            let diff = (h2 * 60 + m2) - (h1 * 60 + m1);
            if (diff < 0) diff += 24 * 60; // Handle overnight
            return diff / 60; // Returns hours
        }

        function renderDashboard() {
            if (document.getElementById('section-dashboard').classList.contains('hidden')) return;

            document.getElementById('stat-total').innerText = localData.length;
            
            const monthlyCounts = {};
            const monthlyHours = {};
            const unitFrequency = {};
            
            localData.forEach(r => {
                if (r.tanggal) {
                    const monthKey = r.tanggal.substring(0, 7); // YYYY-MM
                    monthlyCounts[monthKey] = (monthlyCounts[monthKey] || 0) + 1;
                    
                    const hours = calculateDuration(r.time_start, r.time_stop);
                    monthlyHours[monthKey] = (monthlyHours[monthKey] || 0) + hours;
                }
                if (r.code_unit) {
                    unitFrequency[r.code_unit] = (unitFrequency[r.code_unit] || 0) + 1;
                }
            });

            // 1. Render Monthly Report Counts
            const sortedMonths = Object.keys(monthlyCounts).sort().reverse().slice(0, 5);
            const maxCounts = Math.max(...Object.values(monthlyCounts), 1);
            document.getElementById('monthly-stats-container').innerHTML = sortedMonths.map(m => {
                const count = monthlyCounts[m];
                const percentage = (count / maxCounts) * 100;
                return `
                    <div class="space-y-1">
                        <div class="flex justify-between text-[10px] uppercase font-bold text-slate-400 px-1">
                            <span>${m}</span>
                            <span>${count} Lap.</span>
                        </div>
                        <div class="stat-bar">
                            <div class="stat-fill-blue" style="width: ${percentage}%"></div>
                        </div>
                    </div>
                `;
            }).join('') || '<p class="text-center text-slate-500 py-4 italic text-sm">Tidak ada data tren</p>';

            // 2. Render Monthly Hours & Calculate Max/Min
            const hourValues = Object.values(monthlyHours);
            if (hourValues.length > 0) {
                const maxH = Math.max(...hourValues);
                const minH = Math.min(...hourValues);
                const maxMonth = Object.keys(monthlyHours).find(key => monthlyHours[key] === maxH);
                const minMonth = Object.keys(monthlyHours).find(key => monthlyHours[key] === minH);

                document.getElementById('stat-max-month').innerText = maxMonth;
                document.getElementById('stat-max-val').innerText = maxH.toFixed(1) + 'h';
                document.getElementById('stat-min-month').innerText = minMonth;
                document.getElementById('stat-min-val').innerText = minH.toFixed(1) + 'h';

                document.getElementById('monthly-hours-container').innerHTML = sortedMonths.map(m => {
                    const hours = monthlyHours[m] || 0;
                    const percentage = (hours / maxH) * 100;
                    return `
                        <div class="space-y-1">
                            <div class="flex justify-between text-[10px] uppercase font-bold text-slate-400 px-1">
                                <span>${m}</span>
                                <span>${hours.toFixed(1)} Hours</span>
                            </div>
                            <div class="stat-bar">
                                <div class="stat-fill-purple" style="width: ${percentage}%"></div>
                            </div>
                        </div>
                    `;
                }).join('');
            }

            // 3. Unit Teraktif
            const activeUnit = Object.keys(unitFrequency).reduce((a, b) => unitFrequency[a] > unitFrequency[b] ? a : b, '-');
            document.getElementById('stat-unit').innerText = activeUnit;
        }

        function switchMenu(id) {
            document.querySelectorAll('.content-section').forEach(s => s.classList.add('hidden'));
            document.getElementById(`section-${id}`).classList.remove('hidden');
            document.querySelectorAll('.menu-item').forEach(m => m.classList.remove('active-menu'));
            if(document.getElementById(`btn-${id}`)) document.getElementById(`btn-${id}`).classList.add('active-menu');
            lucide.createIcons();
            if (id === 'dashboard') {
                setTimeout(renderDashboard, 150);
            }
        }

        function toggleLoader(s, t) {
            const l = document.getElementById('loader');
            if(s) { document.getElementById('loader-text').innerText = t; l.classList.remove('hidden'); l.classList.add('flex'); }
            else { l.classList.add('hidden'); l.classList.remove('flex'); }
        }
    </script>
</body>
</html>
